# Copy this to .env for local dev, or set these in Streamlit Cloud -> Secrets tab

# Groq API key for fast LLM scoring (free tier at console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# DJ's IT Audit push notifications (ntfy app)
NTFY_TOPIC=dj-audit-786543

# Pooja's Biotech/Pharma push notifications (ntfy app)
POOJA_NTFY_TOPIC=pooja-industry-oppor

# GitHub Personal Access Token — keeps scan results alive across Streamlit redeploys
# Create at: github.com/settings/tokens → New token → check "repo" scope
GITHUB_TOKEN=your_github_pat_here
GITHUB_REPO=djha786543-gif/Mobilejobnotifications
